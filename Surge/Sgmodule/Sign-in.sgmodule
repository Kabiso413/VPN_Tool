#!name = Sign-in
#!desc = 哔哩哔哩、喜马拉雅、百度贴吧签到合集

[Script]
B站每日任务 = type=cron,cronexp=1 0 * * *,script-path=https://raw.githubusercontent.com/ClydeTime/Surge/main/Script/Task/BiliBili.js,wake-system=1,timeout=15

喜马拉雅签到 = type=cron,cronexp=2 0 * * *,script-path=https://raw.githubusercontent.com/ClydeTime/Surge/main/Script/Task/xmly.js,wake-system=1,timeout=15

# 百度贴吧签到 = script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/tieba/tieba.js,type=cron,cronexp=3 0 * * *,script-update-interval=0
